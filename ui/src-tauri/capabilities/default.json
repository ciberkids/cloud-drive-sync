{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Cloud Drive Sync",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "bin/cloud-drive-sync-daemon", "sidecar": true, "args": true }]
    },
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask"
  ]
}
