meta {
  name: Set Notifications
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/settings/notifications
  body: json
}

body:json {
  {
    "notify_sync_complete": true,
    "notify_conflicts": true,
    "notify_errors": false
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
}
