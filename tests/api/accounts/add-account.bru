meta {
  name: Add Account (headless)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/accounts
  body: json
}

body:json {
  {
    "provider": "gdrive",
    "headless": true
  }
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("response has status field", function() {
    expect(res.body).to.have.property("status");
  });
  test("headless flag was accepted", function() {
    // In demo mode: status is "ok"
    // Without auth callback: status is "no_auth_callback"
    // Both are valid — the important thing is the request didn't fail
    expect(["ok", "no_auth_callback", "error"]).to.include(res.body.status);
  });
}
