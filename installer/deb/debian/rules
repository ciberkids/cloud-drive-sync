#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	# Binaries
	install -Dm755 cloud-drive-sync-daemon $(CURDIR)/debian/cloud-drive-sync/usr/bin/cloud-drive-sync-daemon
	install -Dm755 cloud-drive-sync-ui $(CURDIR)/debian/cloud-drive-sync/usr/bin/cloud-drive-sync-ui

	# Systemd user service
	install -Dm644 cloud-drive-sync-daemon.service \
		$(CURDIR)/debian/cloud-drive-sync/usr/lib/systemd/user/cloud-drive-sync-daemon.service

	# Desktop files
	install -Dm644 cloud-drive-sync-ui.desktop \
		$(CURDIR)/debian/cloud-drive-sync/etc/xdg/autostart/cloud-drive-sync-ui.desktop
	install -Dm644 cloud-drive-sync.desktop \
		$(CURDIR)/debian/cloud-drive-sync/usr/share/applications/cloud-drive-sync.desktop

	# Icons
	install -Dm644 cloud-drive-sync.svg \
		$(CURDIR)/debian/cloud-drive-sync/usr/share/icons/hicolor/scalable/apps/cloud-drive-sync.svg

override_dh_auto_build:
	# Pre-built binaries, nothing to build

override_dh_auto_test:
	# Skip tests for pre-built binaries

override_dh_shlibdeps:
	# Skip automatic shared library dependency detection for pre-built binaries
	true
